# Copy this file to ".env" and fill in your values:  cp .env.example .env
# ".env" is gitignored — never commit your real PAT.
# Loaded automatically by the npm scripts (node --env-file-if-exists=.env).

# Your tenant's Orchestrator URL + the literal "orchestrator_" suffix.
# Find <org>/<tenant> in the browser address bar while using Orchestrator.
UIPATH_BASE_URL=https://cloud.uipath.com/<org>/<tenant>/orchestrator_

# Personal Access Token (read-only scopes). See README → "Generating the PAT".
# Generated in: Automation Cloud → user icon → Preferences → Personal Access Token.
# Copy it immediately on creation — it's shown only once.
UIPATH_PAT=

# OPTIONAL — default folder id (X-UIPATH-OrganizationUnitId). Leave empty to
# pass folderId per tool / resolve folders by name via find_folders.
ORG_UNIT_ID=

# OPTIONAL — client-side rate limit (token bucket). Defaults: 20 / 5.
RATE_LIMIT_BURST=20
RATE_LIMIT_PER_SEC=5
